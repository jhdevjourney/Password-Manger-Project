{
  "name": "password-manager",
  "version": "1.0.0",
  "description": "Secure Local Password Manager Desktop Application",
  "main": "main.js",
  "author": "Your Name",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --debug",
    "build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "crypto-js": "^4.1.0"
  },
  "build": {
    "appId": "com.jhdevjourney.passwordmanager",
    "productName": "Password Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
